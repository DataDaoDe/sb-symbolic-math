{
  "name": "@socrates/math-wasm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./pkg/index.js",
  "module": "./pkg/index.js",
  "types": "./pkg/index.d.ts",
  "files": [
    "pkg"
  ],
  "scripts": {
    "build": "wasm-pack build ../../crates/socrates-math-wasm --target web --out-dir ../../packages/math-wasm/pkg --out-name index",
    "clean": "rm -rf pkg",
    "typecheck": "test -f pkg/index.d.ts || echo 'Skipping @socrates/math-wasm typecheck: run pnpm --filter @socrates/math-wasm build after installing wasm-pack.'"
  }
}
